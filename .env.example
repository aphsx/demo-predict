POSTGRES_DB=moby
POSTGRES_USER=moby
POSTGRES_PASSWORD=moby1234
DATABASE_URL=postgresql://moby:moby1234@db:5432/moby
MODEL_DIR=/app/models
DATA_DIR=/data
REDIS_HOST=redis
DOCKER_BUILD=1
API_URL=http://ml:8000
ELYSIA_URL=http://api:3002
# Internal service token — shared between Elysia and FastAPI for /internal/* routes
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=change-me-to-a-random-secret
# Elysia uses this to reach FastAPI internally (Docker service name)
ML_INTERNAL_URL=http://ml:8000
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# ── better-auth ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-32-byte-string
# Phase 3+: Better Auth now lives in the Elysia API service (port 3002 in dev)
BETTER_AUTH_URL=http://localhost:3002
# Exposed to Next.js browser client so it knows where to send auth requests
NEXT_PUBLIC_AUTH_URL=http://localhost:3002

# OAuth providers
# Google     → https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redirect URIs to register in Google Cloud Console:
#   http://localhost:3002/api/auth/callback/google   ← Elysia (Phase 3+)
#   http://localhost:3001/api/auth/callback/google   ← Next.js (Phase 0-2, now unused)