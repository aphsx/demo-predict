POSTGRES_DB=moby
POSTGRES_USER=moby
POSTGRES_PASSWORD=moby1234
DATABASE_URL=postgresql://moby:moby1234@db:5432/moby
MODEL_DIR=/app/models
DATA_DIR=/data
# Cutoff date for model training (YYYY-MM-DD).
# Must be a date where labelled outcomes exist — i.e. your data continues for
# at least 6 months after this date so churn labels can be computed.
# Override per-run via POST /model-versions/train { "cutoff_date": "2026-01-01" }
TRAIN_CUTOFF_DATE=2025-07-01
REDIS_HOST=redis
DOCKER_BUILD=1
# Phase 5: Elysia is on port 3001; Next.js proxy rewrites all /api/* to this URL (Docker internal)
ELYSIA_URL=http://api:3001
# Browser-visible origin for Eden Treaty + Better Auth client (must be Next.js :3000)
NEXT_PUBLIC_AUTH_URL=http://localhost:3000
# Internal service token — shared between Elysia and FastAPI for /internal/* routes
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=change-me-to-a-random-secret
# Elysia uses this to reach FastAPI internally (Docker service name)
ML_INTERNAL_URL=http://ml:8000
# Next.js (port 3000) is the allowed browser origin for Elysia's CORS
ALLOWED_ORIGINS=http://localhost:3000

# ── Access control (org-shared model) ──────────────────────
# Comma-separated emails that are always treated as admin (role bootstrap).
# Admins can import data, trigger training, delete anything, pin champions.
# Everyone else defaults to role 'member' (view everything + create runs).
ADMIN_EMAILS=
# Runs stuck in a non-terminal status longer than this are marked failed.
STALE_RUN_TIMEOUT_MINUTES=120
# Timeout for Elysia → FastAPI internal calls (ms).
ML_INTERNAL_TIMEOUT_MS=30000

# ── better-auth ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-32-byte-string
# Public-facing URL used for OAuth callbacks. Must match what Google is given.
# Auth flows through the Next.js proxy (/api/auth/*), so this is the Next.js URL.
BETTER_AUTH_URL=http://localhost:3000
# Do NOT set NEXT_PUBLIC_BETTER_AUTH_URL — use NEXT_PUBLIC_AUTH_URL above.

# OAuth providers
# Google     → https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redirect URI to register in Google Cloud Console:
#   http://localhost:3001/api/auth/callback/google   ← Elysia (port 3001)

# ── R2 model artifact storage (optional) ──────────────────
# Leave all unset for local filesystem (default Docker volume).
# When all four are set: train.py uploads artifacts after training,
# predict_worker.py downloads them before inference.
# Get from Cloudflare dashboard → R2 → Manage R2 API tokens
R2_BUCKET=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=

# ── LLM — Gen AI (/customers) + AI Chat (/ai-chat) ใช้ตัวเดียวกัน
# New canonical names (preferred):
#   LLM_PROVIDER    openai | ollama           (default: ollama)
#   LLM_API_KEY     API key / Bearer token
#   LLM_BASE_URL    Base URL without trailing slash
#   LLM_MODEL       Chat model
#   LLM_EMBED_MODEL Embedding model name (for RAG)
# Legacy Ollama names (still supported as fallback):
LLM_PROVIDER=ollama
LLM_API_KEY=
LLM_BASE_URL=https://ollama.com
LLM_MODEL=qwen3.5:397b-cloud
LLM_EMBED_MODEL=embeddinggemma
# Legacy aliases (fallback to LLM_* above if unset):
OLLAMA_API_KEY=
OLLAMA_HOST=
OLLAMA_MODEL=

# ── AI Chat v2 RAG (embeddings + retrieval) ────────────────
# Embedding model used to vectorize knowledge chunks + queries (pgvector).
# embeddinggemma and nomic-embed-text are both 768-dim. If you change the model
# to one with a different dimension, update vector(768) in db/init/001_schema.sql.
# How many knowledge chunks to retrieve per question.
AI_RAG_TOP_K=5
