POSTGRES_DB=moby
POSTGRES_USER=moby
POSTGRES_PASSWORD=moby1234
DATABASE_URL=postgresql://moby:moby1234@db:5432/moby
MODEL_DIR=/app/models
DATA_DIR=/data
# Cutoff date for model training (YYYY-MM-DD).
# Must be a date where labelled outcomes exist — i.e. your data continues for
# at least 6 months after this date so churn labels can be computed.
# Override per-run via POST /model-versions/train { "cutoff_date": "2026-01-01" }
TRAIN_CUTOFF_DATE=2025-07-01
REDIS_HOST=redis
DOCKER_BUILD=1
# Phase 5: Elysia is on port 3001; Next.js proxy rewrites all /api/* to this URL (Docker internal)
ELYSIA_URL=http://api:3001
# Browser-visible origin for Eden Treaty + Better Auth client (must be Next.js :3000)
NEXT_PUBLIC_AUTH_URL=http://localhost:3000
# Internal service token — shared between Elysia and FastAPI for /internal/* routes
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=change-me-to-a-random-secret
# Elysia uses this to reach FastAPI internally (Docker service name)
ML_INTERNAL_URL=http://ml:8000
# Next.js (port 3000) is the allowed browser origin for Elysia's CORS
ALLOWED_ORIGINS=http://localhost:3000

# Local-only auth bypass for UI work. Never enable this outside development.
DEV_AUTH_BYPASS=false
NEXT_PUBLIC_DEV_AUTH_BYPASS=false
# Optional: set this to an existing prediction_runs.user_id if you want to see that user's runs.
DEV_AUTH_BYPASS_USER_ID=dev-local-user

# ── better-auth ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-32-byte-string
# Public-facing URL used for OAuth callbacks. Must match what Google is given.
# Auth flows through the Next.js proxy (/api/auth/*), so this is the Next.js URL.
BETTER_AUTH_URL=http://localhost:3000
# Do NOT set NEXT_PUBLIC_BETTER_AUTH_URL — use NEXT_PUBLIC_AUTH_URL above.

# OAuth providers
# Google     → https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redirect URI to register in Google Cloud Console:
#   http://localhost:3001/api/auth/callback/google   ← Elysia (port 3001)

# ── R2 model artifact storage (optional) ──────────────────
# Leave all unset for local filesystem (default Docker volume).
# When all four are set: train.py uploads artifacts after training,
# predict_worker.py downloads them before inference.
# Get from Cloudflare dashboard → R2 → Manage R2 API tokens
R2_BUCKET=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=

# ── LLM (Phase 2) ──────────────────────────────────────────
# Get from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional — defaults to gemini-1.5-flash
GEMINI_MODEL=gemini-1.5-flash
