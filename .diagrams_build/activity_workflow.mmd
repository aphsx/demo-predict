%%{init: {'theme':'default'}}%%
flowchart TD
    Start([Start])

    A1[User opens /runs page]
    A2[Fill name + cutoff_date<br/>Click Create]
    A3["POST /runs<br/>(status = pending)"]
    A4[Select Excel file<br/>Click Upload]
    A5["POST /runs/&#123;id&#125;/upload"]

    V{Validate sheets<br/>+ schema?}
    Vfail[status = failed<br/>save error_message]
    EndFail([End: Failed])

    I1["INSERT raw_customers<br/>raw_payments<br/>raw_usage"]
    I2[status = validating]
    I3[Enqueue job to Redis ARQ]
    I4[status = processing]

    subgraph WORKER [ARQ Worker - Background]
        direction TB
        W1[Dequeue job]
        W2[Load raw data from DB]
        W3[build_features<br/>30 features point-in-time safe]
        W4[Run Churn Model<br/>LightGBM + Isotonic]
        W5[Run CLV Model<br/>BG/NBD + Gamma-Gamma]
        W6[Run Credit Model<br/>Quantile LightGBM x5]
        W7[Compute RFM segment<br/>+ Priority Score<br/>+ Revenue at risk]
        W8[SHAP top-500 active]
        W9[Batch INSERT predictions<br/>1000 rows/trip]
        W10[UPDATE prediction_runs<br/>status = done]
    end

    subgraph FE [Frontend Polling - every 5s]
        direction TB
        P1["Poll GET /runs/&#123;id&#125;"]
        Pcheck{status?}
    end

    R1[View Dashboard<br/>GET /summary]
    R2[Browse /customers<br/>filter + paginate]
    R3[Click acc_id<br/>open Customer 360]
    R4[See Churn gauge,<br/>CLV CI, RFM,<br/>Credit quantiles,<br/>Sales recommendation]
    EndOK([End: Success])

    Start --> A1 --> A2 --> A3 --> A4 --> A5 --> V
    V -- No --> Vfail --> EndFail
    V -- Yes --> I1 --> I2 --> I3 --> I4
    I3 --> W1 --> W2 --> W3 --> W4 --> W5 --> W6 --> W7 --> W8 --> W9 --> W10

    I4 --> P1 --> Pcheck
    Pcheck -- processing --> P1
    Pcheck -- failed --> EndFail
    Pcheck -- done --> R1 --> R2 --> R3 --> R4 --> EndOK

    W10 -. notify .-> Pcheck
